# ─── Market Data API Keys (Vercel 환경변수에 등록 필수) ─────────
# 한국수출입은행 환율 API (https://www.koreaexim.go.kr → 오픈API → 인증키 발급)
KOREAEXIM_KEY=

# 한국은행 ECOS 통계 API (https://ecos.bok.or.kr → Open API → 인증키 발급)
BOK_KEY=

# FRED 미국 경제 데이터 API (https://fred.stlouisfed.org → My Account → API Keys)
FRED_KEY=

# Alpha Vantage 주가 API (https://www.alphavantage.co/support/#api-key 에서 무료 발급)
ALPHA_VANTAGE_KEY=
